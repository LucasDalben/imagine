{
  "expo": {
    "name": "Imagine",
    "slug": "imagine",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/imagine_logo.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/imagem_inicial_tela.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1B3E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.imagine.kids"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/imagine_logo.png",
        "backgroundColor": "#0D1B3E"
      },
      "package": "com.imagine.kids"
    },
    "plugins": [
      "expo-router",
      "expo-video"
    ],
    "scheme": "imagine",
    "experiments": {
      "typedRoutes": true
    }
  }
}
